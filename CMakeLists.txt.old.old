cmake_minimum_required(VERSION 3.15)
project(MyProject C)

set(CMAKE_C_STANDARD 99)
set(CMAKE_C_STANDARD_REQUIRED ON)

# Build options
option(BUILD_STATIC "Build static executable" OFF)

include(ExternalProject)
include(FetchContent)

# Set up external project paths
set(EXTERNAL_INSTALL_LOCATION ${CMAKE_BINARY_DIR}/external)

# Create external directories if they do not exist 
file(MAKE_DIRECTORY ${EXTERNAL_INSTALL_LOCATION}) 
file(MAKE_DIRECTORY ${EXTERNAL_INSTALL_LOCATION}/include) 
file(MAKE_DIRECTORY ${EXTERNAL_INSTALL_LOCATION}/lib)

set(DEPS_LOCATION ${CMAKE_BINARY_DIR}/_deps)

# Detect toolchain
if(CMAKE_C_COMPILER_ID MATCHES "GNU")
    set(USING_GCC 1)
elseif(CMAKE_C_COMPILER_ID MATCHES "MSVC")
    set(USING_MSVC 1)
endif()

if(WIN32 AND USING_GCC)
    set(USING_MINGW 1)
endif()

# Platform-specific settings
if(USING_MINGW)
    # MinGW specific flags
    set(CMAKE_C_FLAGS "${CMAKE_C_FLAGS} -static-libgcc -static-libstdc++")
    # Prevent MinGW from adding extra dependencies
    # set(CMAKE_EXE_LINKER_FLAGS "${CMAKE_EXE_LINKER_FLAGS} -static -lpthread")
endif()

# LuaJIT setup
if(USING_MSVC)
    set(LUAJIT_MAKE_CMD msvcbuild.bat)
    set(LUAJIT_FILE_NAME lua51.dll)
elseif(USING_MINGW)
    # MinGW needs specific make command and flags
    set(LUAJIT_MAKE_CMD mingw32-make)
    set(LUAJIT_MAKE_FLAGS HOST_CC="gcc -m32" CROSS=x86_64-w64-mingw32- TARGET_SYS=Windows)
    set(LUAJIT_FILE_NAME libluajit.a)
else()
    # Unix/Linux
    set(LUAJIT_MAKE_CMD make)
    set(LUAJIT_MAKE_FLAGS TARGET_CFLAGS=-fPIC)
    set(LUAJIT_FILE_NAME libluajit.a)
endif()

set(LUAJIT_STATIC_LIB ${EXTERNAL_INSTALL_LOCATION}/lib/${LUAJIT_FILE_NAME})

ExternalProject_Add(
    luajit_external
    GIT_REPOSITORY https://github.com/LuaJIT/LuaJIT.git
    GIT_TAG v2.1
    PREFIX ${DEPS_LOCATION}/luajit
    CONFIGURE_COMMAND "" # LuaJIT uses make directly
    BUILD_IN_SOURCE 1
    BUILD_COMMAND
        ${CMAKE_COMMAND} -E chdir src ${LUAJIT_MAKE_CMD} ${LUAJIT_MAKE_FLAGS}
    INSTALL_COMMAND
        ${CMAKE_COMMAND} -E copy src/${LUAJIT_FILE_NAME} ${LUAJIT_STATIC_LIB} &&
        ${CMAKE_COMMAND} -E copy_directory src ${EXTERNAL_INSTALL_LOCATION}/include
    BUILD_BYPRODUCTS ${LUAJIT_STATIC_LIB}
)

# raylib setup with platform-specific configurations
set(PLATFORM_DEFINES)
if(USING_MINGW)
    set(PLATFORM_DEFINES -D_WIN32 -DPLATFORM_DESKTOP)
endif()

FetchContent_Declare(
    raylib
    GIT_REPOSITORY https://github.com/raysan5/raylib.git
    GIT_TAG 4.5.0
)

# Configure raylib build options
set(BUILD_SHARED_LIBS OFF CACHE BOOL "" FORCE)
set(BUILD_EXAMPLES OFF CACHE BOOL "" FORCE)
set(BUILD_GAMES OFF CACHE BOOL "" FORCE)

# Platform specific raylib options
if(USING_MINGW)
    set(USE_EXTERNAL_GLFW ON CACHE BOOL "" FORCE)
    set(SUPPORT_WINMM ON CACHE BOOL "" FORCE)
endif()

FetchContent_MakeAvailable(raylib)

# Create interface library for LuaJIT
add_library(luajit_static STATIC IMPORTED GLOBAL)
add_dependencies(luajit_static luajit_external)

set_target_properties(luajit_static PROPERTIES
    IMPORTED_LOCATION ${LUAJIT_STATIC_LIB}
    INTERFACE_INCLUDE_DIRECTORIES ${EXTERNAL_INSTALL_LOCATION}/include
)

# Your executable
add_executable(myapp src/main.c)

# Platform-specific linking
if(BUILD_STATIC)
    if(UNIX)
        target_link_options(myapp PRIVATE -static-libgcc -static)
        target_link_libraries(myapp PRIVATE dl m)
    elseif(USING_MINGW)
        target_link_libraries(myapp PRIVATE 
            mingw32 
            pthread
            winmm
            gdi32
            kernel32
        )
    endif()
endif()

target_link_libraries(myapp PRIVATE 
    raylib
    luajit_static
)

# Platform-specific compiler options
if(USING_MSVC)
    target_compile_options(myapp PRIVATE /W4)
else()
    target_compile_options(myapp PRIVATE -Wall -Wextra)
endif()

# Add platform-specific definitions
target_compile_definitions(myapp PRIVATE ${PLATFORM_DEFINES})

# Toolchain file example for MinGW cross-compilation from Linux
file(WRITE ${CMAKE_CURRENT_SOURCE_DIR}/mingw-w64-toolchain.cmake [[
# MinGW-w64 toolchain file
set(CMAKE_SYSTEM_NAME Windows)
set(CMAKE_SYSTEM_PROCESSOR x86_64)

# Paths to MinGW toolchain
set(MINGW_PREFIX x86_64-w64-mingw32)
set(CMAKE_C_COMPILER ${MINGW_PREFIX}-gcc)
set(CMAKE_CXX_COMPILER ${MINGW_PREFIX}-g++)
set(CMAKE_RC_COMPILER ${MINGW_PREFIX}-windres)

# Search paths
set(CMAKE_FIND_ROOT_PATH /usr/${MINGW_PREFIX})
set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)

# Static linking flags
set(CMAKE_C_FLAGS "${CMAKE_C_FLAGS} -static-libgcc")
set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -static-libgcc -static-libstdc++")
set(CMAKE_EXE_LINKER_FLAGS "${CMAKE_EXE_LINKER_FLAGS} -static")
]])

# Example main.c with platform-specific includes
file(WRITE ${CMAKE_CURRENT_SOURCE_DIR}/src/main.c [[
#include <raylib.h>
//#include <luajit.h>
//#include <lualib.h>
//#include <lauxlib.h>


int main(void) {
    // Initialize Lua
//    lua_State *L = luaL_newstate();
//    luaL_openlibs(L);
    
    // Initialize raylib window
    InitWindow(800, 450, "raylib + LuaJIT example");
    SetTargetFPS(60);
    
    while (!WindowShouldClose()) {
        BeginDrawing();
        ClearBackground(RAYWHITE);
        DrawText("Hello from raylib + LuaJIT!", 190, 200, 20, LIGHTGRAY);
        EndDrawing();
    }
    
    // Cleanup
//    lua_close(L);
    CloseWindow();
    return 0;
}
]])
